generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Provider {
  STRIPE
  FEDAPAY
  CINETPAY
  BIZAO
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model User {
  id            String        @id @default(uuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role          @default(USER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts     Account[]
  sessions     Session[]
  Consents     Consent[]
  Transactions Transaction[]
}

model Consent {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  cguAccepted     Boolean
  privacyAccepted Boolean
  version         String
  acceptedAt      DateTime
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  amount      Decimal           @db.Decimal(10, 2)
  currency    String
  country     String            // ISO country code
  provider    Provider
  status      TransactionStatus
  providerRef String?
  // Stored at payment-intent creation (decoded from ephemeral token).
  // Not exposed in GlobalStat — kept here only for webhook processing.
  resultType  String?
  createdAt   DateTime          @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// IMPORTANT: GlobalStat MUST NOT contain any @relation fields or links to
// `User` or `Transaction`. This model is intentionally independent to ensure
// mathematical anonymity and to respect the RGPD "zero-storage medical" principle.
// Do NOT add fields with `@relation` that point to `User` or `Transaction`.
model GlobalStat {
  id                 String   @id @default(uuid())
  date               DateTime
  country            String   // anonymised ISO country code
  exclusionCount     Int
  compatibilityCount Int

  @@unique([date, country])
}
